.env
.env.local
.env.*.local
*.bak
*.log
.DS_Store
Thumbs.db
node_modules/

# IDE / agent local configs (user-specific)
# .claude/ : ignore settings.json + settings.local.json (machine-local
# permissions + personal overrides) but track the modular Claude config
# under rules/, skills/, agents/, commands/.
.claude/*
!.claude/rules/
!.claude/rules/**
!.claude/skills/
!.claude/skills/**
!.claude/agents/
!.claude/agents/**
!.claude/commands/
!.claude/commands/**
.vscode/
.codex

# Defensive: never commit certs / private keys
*.pem
*.key
*.crt
