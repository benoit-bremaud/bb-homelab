# Copy to .env and fill in. .env is gitignored.

# Image tag — bump deliberately (test before rolling out).
# JELLYFIN_IMAGE_TAG=10.11.9

# Timezone (defaults to Europe/Paris if unset).
# TZ=Europe/Paris

# Base URL advertised to clients. Defaults to the Caddy hostname; set to
# the direct address (e.g. http://bb-homelab:8096) if you skip Caddy.
# JELLYFIN_PUBLISHED_URL=https://jellyfin.bb-homelab.local

# No secrets here: the admin account is created in the Jellyfin setup
# wizard on first start, not via environment variables.
