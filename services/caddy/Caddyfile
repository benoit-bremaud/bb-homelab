# bb-homelab reverse proxy — phase 1 (tailnet-only, TLS via internal CA).
#
# Every route below uses Caddy's internal CA (`tls internal`) because no
# public domain is owned yet (decision #28). When a domain arrives, swap
# `tls internal` for the default ACME flow (just remove the directive
# and rename the hosts to the public FQDN).
#
# Root CA to install on every client device (laptop, phone, family
# laptops). Copy it from the container after the first start:
#   docker exec bb-homelab-caddy cat /data/caddy/pki/authorities/local/root.crt
# See services/caddy/README.md for the full install procedure.
# (no global options block — admin API listens on its default
# localhost:2019 inside the container only; not exposed to the host
# or to the bb-homelab-proxy network. Required by `caddy reload` to
# apply Caddyfile changes without restarting the container.)

# ---- n8n ----
# n8n.bb-homelab.local → n8n container on the shared proxy network.
# Client devices add a single /etc/hosts entry pointing *.bb-homelab.local
# to the Pi's Tailscale IP; routing is handled here.
n8n.bb-homelab.local {
	tls internal
	reverse_proxy n8n:5678
}

# ---- jellyfin ----
# jellyfin.bb-homelab.local → Jellyfin media server on the shared proxy
# network. Browsers that trust the internal CA use this hostname; TV /
# mobile apps that cannot install the CA use the direct port instead
# (http://bb-homelab:8096, published by services/jellyfin/).
jellyfin.bb-homelab.local {
	tls internal
	reverse_proxy jellyfin:8096
}

# ---- Uptime Kuma ----
# status.bb-homelab.local → uptime-kuma container (Stack B monitoring,
# issue #44). Reached over the shared bb-homelab-proxy network.
status.bb-homelab.local {
	tls internal
	reverse_proxy uptime-kuma:3001
}

# ---- Vaultwarden ----
# vaultwarden.bb-homelab.local → vaultwarden container (password manager,
# issue #25). Reached over the shared bb-homelab-proxy network. A single
# reverse_proxy is sufficient: since Vaultwarden 1.31 the WebSocket
# (/notifications/hub) is served by Rocket on the same port 80, and Caddy
# upgrades WebSocket connections automatically — no separate hub block.
# X-Real-IP is forwarded so Vaultwarden logs the true tailnet client IP
# (for its admin-panel rate-limiting / fail2ban) instead of Caddy's
# container IP.
vaultwarden.bb-homelab.local {
	tls internal
	reverse_proxy vaultwarden:80 {
		header_up X-Real-IP {remote_host}
	}
}

# ---- Homepage (landing dashboard) ----
# home.bb-homelab.local → homepage container (link launcher + status,
# issue #125). Reached over the shared bb-homelab-proxy network. The
# upstream is the compose SERVICE name `homepage` (like uptime-kuma:3001),
# not the hostname `home`.
home.bb-homelab.local {
	tls internal
	reverse_proxy homepage:3000
}

# ---- Health check ----
# Plain-HTTP liveness endpoint for the Docker healthcheck (see
# docker-compose.yml). Scoped to the `localhost` host on HTTP only, so it
# never collides with the *.bb-homelab.local sites above and needs no TLS —
# the in-container probe cannot verify the internal CA. Returns 200.
http://localhost {
	handle /healthz {
		respond 200
	}
}
