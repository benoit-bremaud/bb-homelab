# Copy this file to .env and fill in the values. .env is gitignored.

# Generate with: openssl rand -hex 32
# IMPORTANT: this key encrypts your credentials in n8n. Lose it = lose them.
# REQUIRED: docker compose up will fail fast if this is empty.
N8N_ENCRYPTION_KEY=

# --- Image pinning (override to bump deliberately) ---
# N8N_IMAGE_TAG=1.97.1
# CLOUDFLARED_IMAGE_TAG=2024.8.3

# Optional: timezone (default Europe/Paris).
TZ=Europe/Paris

# n8n public URL announced in webhooks (filled after cloudflared first start).
# Find it in: docker compose logs cloudflared | grep trycloudflare.com
WEBHOOK_URL=https://your-tunnel.trycloudflare.com
N8N_HOST=your-tunnel.trycloudflare.com

# --- Future: stable named tunnel (when you have a Cloudflare domain) ---
# CLOUDFLARE_TUNNEL_TOKEN=

# --- Used inside n8n workflows (set via n8n UI as credentials) ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# ANTHROPIC_API_KEY=
# GITHUB_TOKEN=
