# Copy to .env and fill in. .env is gitignored.

# Image tag — bump deliberately (test before rolling out).
# HOMEPAGE_IMAGE_TAG=v1.13.2

# Timezone (defaults to Europe/Paris if unset).
# TZ=Europe/Paris

# Host-header allowlist (required since Homepage v1.0 for non-localhost
# access). Defaults to the Caddy hostname.
# HOMEPAGE_ALLOWED_HOSTS=home.bb-homelab.local

# No secrets here: Level 1/2 needs none. The Uptime Kuma widget (PR2)
# reads a PUBLIC status page by slug — no API key, no login.
