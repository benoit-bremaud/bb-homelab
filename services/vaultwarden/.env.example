# Copy this file to .env and fill in the values. .env is gitignored.
# Never commit .env. All real secrets live there only.

# --- ADMIN_TOKEN: Argon2 PHC hash of your admin password (NOT plaintext) ---
# Generate the hash (interactive, asks for the password twice):
#   docker run --rm -it vaultwarden/server /vaultwarden hash
# It prints a PHC string of the form:
#   $argon2id$v=19$m=65540,t=3,p=4$<salt>$<hash>
#
# IMPORTANT (Docker Compose .env): WRAP the hash in SINGLE QUOTES and keep
# single '$'. Single-quoted .env values are used literally, so Compose does
# NOT interpolate the '$...' segments. Do NOT double the '$' — doubling is
# the escaping rule for inline compose.yml values, not for .env. Example:
#   VW_ADMIN_TOKEN='$argon2id$v=19$m=65540,t=3,p=4$<salt>$<hash>'
#
# REQUIRED: `docker compose up` fails fast if this is empty.
# Store the PLAINTEXT password ONLY in your password manager (break-glass).
# It is the master key to the /admin panel — never commit it, never leave
# it on the Pi.
VW_ADMIN_TOKEN=

# --- Image pinning (override to bump deliberately, then test) ---
# VW_IMAGE_TAG=1.36.0

# --- Public origin (must match the Caddy hostname exactly) ---
# VW_DOMAIN=https://vaultwarden.bb-homelab.local

# --- Registration policy ---
# Leave false. Flip to true ONLY for the one-shot account bootstrap, then
# set back to false and `docker compose up -d` (see README "Bootstrap").
# VW_SIGNUPS_ALLOWED=false
# VW_SIGNUPS_DOMAINS_WHITELIST=

# --- Mobile push (optional, third-party relay via bitwarden.com/host) ---
# VW_PUSH_ENABLED=false
# VW_PUSH_INSTALLATION_ID=
# VW_PUSH_INSTALLATION_KEY=

# --- Misc ---
# TZ=Europe/Paris
# VW_LOG_LEVEL=warn
